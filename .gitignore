# env files — NE PAS COMMITER les fichiers d'environnement sauf .env.example
.env
.env.local
.env.production
.env*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# scratch
/scratch/

# cloudflare / opennext build output
/.open-next/

