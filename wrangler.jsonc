{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "urbateam",
  "main": ".open-next/worker.js",
  // Date de compatibilité — doit être >= 2024-09-23 pour nodejs_compat
  "compatibility_date": "2026-05-31",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
