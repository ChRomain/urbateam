# =============================================================
# Urbateam — Variables d'environnement
# Copier ce fichier en .env.local pour le développement local
# Ne jamais commiter le fichier .env.local ou .env.production !
# =============================================================

# ─── Next.js ─────────────────────────────────────────────────
# URL interne de l'API Directus (depuis le conteneur Next.js)
DIRECTUS_URL=http://directus:8055
# URL publique de Directus (utilisée côté client navigateur)
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055

# Clé statique API Directus pour les lectures publiques (lecture seule)
# À générer dans Directus > Settings > API Keys
DIRECTUS_API_TOKEN=your-static-token-here

# ─── Directus ────────────────────────────────────────────────
DIRECTUS_SECRET=change-me-to-a-random-64-char-string
DIRECTUS_ADMIN_EMAIL=admin@urbateam.fr
DIRECTUS_ADMIN_PASSWORD=ChangeMe!Secure123

# ─── PostgreSQL ──────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=urbateam
DB_USER=urbateam
DB_PASSWORD=change-me-to-a-secure-password

# ─── Production uniquement ───────────────────────────────────
# DIRECTUS_URL=http://directus:8055
# NEXT_PUBLIC_DIRECTUS_URL=https://admin.urbateam.fr
