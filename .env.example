# =============================================================
# Urbateam — Variables d'environnement
# Copier ce fichier en .env.local pour le développement local
# Ne jamais commiter le fichier .env.local ou .env.production !
# =============================================================

# ─── Supabase (Nouvelle Stack Serverless) ──────────────────────
# URL publique de votre projet Supabase (ex: https://your-project.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Clé anonyme publique pour les lectures/écritures publiques autorisées
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Clé de rôle de service (Service Role Key) — REQUIS uniquement pour le script de peuplement (seeding)
# /!\ Ne JAMAIS exposer cette clé côté client ou sur Vercel ! Uniquement dans .env.local
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Next.js (Déprécié / Directus & Docker) ───────────────────
# Les variables suivantes ne sont plus nécessaires avec la stack Supabase + Vercel
# DIRECTUS_URL=http://directus:8055
# NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055
# DIRECTUS_API_TOKEN=your-static-token-here
# DIRECTUS_SECRET=change-me-to-a-random-64-char-string
# DIRECTUS_ADMIN_EMAIL=admin@urbateam.fr
# DIRECTUS_ADMIN_PASSWORD=ChangeMe!Secure123
# DB_HOST=postgres
# DB_PORT=5432
# DB_DATABASE=urbateam
# DB_USER=urbateam
# DB_PASSWORD=change-me-to-a-secure-password

